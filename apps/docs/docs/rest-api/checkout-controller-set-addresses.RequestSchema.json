{
    "title": "Body",
    "body": {
        "required": true,
        "description": "Shipping/billing address payload for checkout.",
        "content": {
            "application/json": {
                "schema": {
                    "type": "object",
                    "properties": {
                        "shippingAddressId": {
                            "type": "string",
                            "description": "Saved shipping address identifier for authenticated users."
                        },
                        "shippingAddress": {
                            "description": "Inline shipping address payload.",
                            "allOf": [{ "type": "object", "properties": {}, "title": "Address" }]
                        },
                        "billingAddressId": {
                            "type": "string",
                            "description": "Saved billing address identifier for authenticated users."
                        },
                        "billingAddress": {
                            "description": "Inline billing address payload.",
                            "allOf": [{ "type": "object", "properties": {}, "title": "Address" }]
                        },
                        "sameAsBillingAddress": { "type": "boolean", "description": "Optional checkout notes." },
                        "notes": { "type": "string", "description": "Optional checkout notes." },
                        "email": {
                            "type": "string",
                            "description": "Customer email, typically required for guest checkout."
                        }
                    },
                    "title": "SetAddressesBody"
                }
            }
        }
    }
}
