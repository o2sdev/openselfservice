{
    "responses": {
        "200": {
            "description": "Returns checkout shipping options.",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "data": {
                                "description": "Available shipping methods",
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "id": { "type": "string", "description": "Shipping method identifier" },
                                        "name": { "type": "string", "description": "Shipping method display name" },
                                        "description": {
                                            "type": "string",
                                            "description": "Shipping method description"
                                        },
                                        "total": {
                                            "type": "object",
                                            "description": "Total shipping cost including tax"
                                        },
                                        "subtotal": { "type": "object", "description": "Shipping cost before tax" }
                                    },
                                    "required": ["id", "name"],
                                    "title": "ShippingMethod"
                                }
                            },
                            "total": { "type": "number", "description": "Total number of available shipping options" }
                        },
                        "required": ["data", "total"],
                        "title": "ShippingOptions"
                    }
                }
            }
        }
    }
}
