{
    "responses": {
        "200": {
            "description": "Returns search results.",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "hits": {
                                "description": "Search result hits (structure depends on search index)",
                                "type": "array",
                                "items": { "type": "array" }
                            },
                            "total": { "type": "number", "description": "Total number of matching results" },
                            "metadata": {
                                "type": "object",
                                "description": "Result metadata",
                                "additionalProperties": true
                            }
                        },
                        "required": ["hits", "total"],
                        "title": "SearchResultResponse"
                    }
                }
            }
        }
    }
}
