{
    "responses": {
        "200": {
            "description": "Returns order list.",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "data": {
                                "description": "Array of orders",
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "id": { "type": "string", "description": "Unique order identifier" },
                                        "customerId": { "type": "string", "description": "Customer identifier" },
                                        "createdAt": {
                                            "type": "string",
                                            "description": "Order creation timestamp in ISO 8601 format"
                                        },
                                        "paymentDueDate": {
                                            "type": "string",
                                            "description": "Payment due date in ISO 8601 format"
                                        },
                                        "updatedAt": {
                                            "type": "string",
                                            "description": "Last update timestamp in ISO 8601 format"
                                        },
                                        "total": {
                                            "type": "object",
                                            "description": "Order total including tax and shipping"
                                        },
                                        "subtotal": {
                                            "type": "object",
                                            "description": "Order subtotal before tax and shipping"
                                        },
                                        "shippingTotal": { "type": "object", "description": "Total shipping cost" },
                                        "shippingSubtotal": {
                                            "type": "object",
                                            "description": "Shipping subtotal before tax"
                                        },
                                        "discountTotal": { "type": "object", "description": "Total discount applied" },
                                        "tax": { "type": "object", "description": "Tax amount" },
                                        "currency": { "type": "string", "description": "Order currency code" },
                                        "paymentStatus": {
                                            "type": "string",
                                            "description": "Current payment status",
                                            "enum": [
                                                "PENDING",
                                                "PAID",
                                                "FAILED",
                                                "REFUNDED",
                                                "NOT_PAID",
                                                "CAPTURED",
                                                "PARTIALLY_REFUNDED",
                                                "REQUIRES_ACTION",
                                                "UNKNOWN"
                                            ]
                                        },
                                        "status": {
                                            "type": "string",
                                            "description": "Current order fulfillment status",
                                            "enum": [
                                                "PENDING",
                                                "COMPLETED",
                                                "SHIPPED",
                                                "CANCELLED",
                                                "ARCHIVED",
                                                "REQUIRES_ACTION",
                                                "UNKNOWN"
                                            ]
                                        },
                                        "items": {
                                            "description": "Order line items",
                                            "allOf": [
                                                {
                                                    "type": "object",
                                                    "properties": {
                                                        "data": {
                                                            "description": "Array of order items",
                                                            "type": "array",
                                                            "items": {
                                                                "type": "object",
                                                                "properties": {
                                                                    "id": {
                                                                        "type": "string",
                                                                        "description": "Order item identifier"
                                                                    },
                                                                    "productId": {
                                                                        "type": "string",
                                                                        "description": "Associated product identifier"
                                                                    },
                                                                    "quantity": {
                                                                        "type": "number",
                                                                        "description": "Quantity ordered"
                                                                    },
                                                                    "price": {
                                                                        "type": "object",
                                                                        "description": "Unit price"
                                                                    },
                                                                    "total": {
                                                                        "type": "object",
                                                                        "description": "Total price for this line item"
                                                                    },
                                                                    "subtotal": {
                                                                        "type": "object",
                                                                        "description": "Subtotal before discounts"
                                                                    },
                                                                    "discountTotal": {
                                                                        "type": "object",
                                                                        "description": "Total discount applied"
                                                                    },
                                                                    "unit": {
                                                                        "type": "string",
                                                                        "description": "Unit of measure"
                                                                    },
                                                                    "currency": {
                                                                        "type": "string",
                                                                        "description": "Currency code"
                                                                    },
                                                                    "product": {
                                                                        "description": "Product details",
                                                                        "allOf": [
                                                                            {
                                                                                "type": "object",
                                                                                "properties": {
                                                                                    "id": {
                                                                                        "type": "string",
                                                                                        "description": "Unique product identifier"
                                                                                    },
                                                                                    "sku": {
                                                                                        "type": "string",
                                                                                        "description": "Stock keeping unit"
                                                                                    },
                                                                                    "name": {
                                                                                        "type": "string",
                                                                                        "description": "Product name"
                                                                                    },
                                                                                    "description": {
                                                                                        "type": "string",
                                                                                        "description": "Full product description"
                                                                                    },
                                                                                    "shortDescription": {
                                                                                        "type": "string",
                                                                                        "description": "Short product description"
                                                                                    },
                                                                                    "subtitle": {
                                                                                        "type": "string",
                                                                                        "description": "Product subtitle"
                                                                                    },
                                                                                    "variantId": {
                                                                                        "type": "string",
                                                                                        "description": "Selected variant identifier"
                                                                                    },
                                                                                    "image": {
                                                                                        "description": "Main product image",
                                                                                        "allOf": [
                                                                                            {
                                                                                                "type": "object",
                                                                                                "properties": {},
                                                                                                "title": "Media"
                                                                                            }
                                                                                        ]
                                                                                    },
                                                                                    "images": {
                                                                                        "description": "Additional product images",
                                                                                        "type": "array",
                                                                                        "items": {
                                                                                            "type": "object",
                                                                                            "properties": {},
                                                                                            "title": "Media"
                                                                                        }
                                                                                    },
                                                                                    "price": {
                                                                                        "type": "object",
                                                                                        "description": "Product price"
                                                                                    },
                                                                                    "link": {
                                                                                        "type": "string",
                                                                                        "description": "Product page URL"
                                                                                    },
                                                                                    "type": {
                                                                                        "type": "string",
                                                                                        "description": "Product type",
                                                                                        "enum": ["PHYSICAL", "VIRTUAL"]
                                                                                    },
                                                                                    "category": {
                                                                                        "type": "string",
                                                                                        "description": "Product category"
                                                                                    },
                                                                                    "tags": {
                                                                                        "description": "Product tags",
                                                                                        "type": "array",
                                                                                        "items": {
                                                                                            "type": "object",
                                                                                            "properties": {
                                                                                                "label": {
                                                                                                    "type": "string",
                                                                                                    "description": "Tag display label"
                                                                                                },
                                                                                                "variant": {
                                                                                                    "type": "string",
                                                                                                    "description": "Visual variant/style of the tag"
                                                                                                }
                                                                                            },
                                                                                            "required": [
                                                                                                "label",
                                                                                                "variant"
                                                                                            ],
                                                                                            "title": "ProductTag"
                                                                                        }
                                                                                    },
                                                                                    "attributes": {
                                                                                        "type": "object",
                                                                                        "description": "Product attributes",
                                                                                        "additionalProperties": {
                                                                                            "oneOf": [
                                                                                                { "type": "string" },
                                                                                                { "type": "number" }
                                                                                            ]
                                                                                        }
                                                                                    },
                                                                                    "location": {
                                                                                        "type": "string",
                                                                                        "description": "Product location/warehouse"
                                                                                    },
                                                                                    "optionGroups": {
                                                                                        "description": "Available option groups",
                                                                                        "type": "array",
                                                                                        "items": {
                                                                                            "type": "object",
                                                                                            "properties": {
                                                                                                "id": {
                                                                                                    "type": "string",
                                                                                                    "description": "Option group identifier"
                                                                                                },
                                                                                                "title": {
                                                                                                    "type": "string",
                                                                                                    "description": "Option group display title"
                                                                                                },
                                                                                                "values": {
                                                                                                    "description": "Available values for this option group",
                                                                                                    "type": "array",
                                                                                                    "items": {
                                                                                                        "type": "string"
                                                                                                    }
                                                                                                }
                                                                                            },
                                                                                            "required": [
                                                                                                "id",
                                                                                                "title",
                                                                                                "values"
                                                                                            ],
                                                                                            "title": "ProductOptionGroup"
                                                                                        }
                                                                                    },
                                                                                    "variants": {
                                                                                        "description": "Product variants",
                                                                                        "type": "array",
                                                                                        "items": {
                                                                                            "type": "object",
                                                                                            "properties": {
                                                                                                "id": {
                                                                                                    "type": "string",
                                                                                                    "description": "Variant identifier"
                                                                                                },
                                                                                                "title": {
                                                                                                    "type": "string",
                                                                                                    "description": "Variant display title"
                                                                                                },
                                                                                                "slug": {
                                                                                                    "type": "string",
                                                                                                    "description": "URL-friendly variant slug"
                                                                                                },
                                                                                                "link": {
                                                                                                    "type": "string",
                                                                                                    "description": "Link to variant page"
                                                                                                },
                                                                                                "options": {
                                                                                                    "type": "object",
                                                                                                    "description": "Selected option values for this variant",
                                                                                                    "additionalProperties": {
                                                                                                        "type": "string"
                                                                                                    }
                                                                                                },
                                                                                                "inStock": {
                                                                                                    "type": "boolean",
                                                                                                    "description": "Whether this variant is in stock"
                                                                                                }
                                                                                            },
                                                                                            "required": [
                                                                                                "id",
                                                                                                "title",
                                                                                                "slug"
                                                                                            ],
                                                                                            "title": "ProductVariantOption"
                                                                                        }
                                                                                    }
                                                                                },
                                                                                "required": [
                                                                                    "id",
                                                                                    "sku",
                                                                                    "name",
                                                                                    "description",
                                                                                    "price",
                                                                                    "link",
                                                                                    "type",
                                                                                    "category",
                                                                                    "tags"
                                                                                ],
                                                                                "title": "Product"
                                                                            }
                                                                        ]
                                                                    }
                                                                },
                                                                "required": [
                                                                    "id",
                                                                    "productId",
                                                                    "quantity",
                                                                    "price",
                                                                    "currency",
                                                                    "product"
                                                                ],
                                                                "title": "OrderItem"
                                                            }
                                                        },
                                                        "total": {
                                                            "type": "number",
                                                            "description": "Total number of items"
                                                        }
                                                    },
                                                    "required": ["data", "total"],
                                                    "title": "OrderItems"
                                                }
                                            ]
                                        },
                                        "purchaseOrderNumber": {
                                            "type": "string",
                                            "description": "Purchase order number for B2B orders"
                                        },
                                        "shippingAddress": {
                                            "description": "Shipping address",
                                            "allOf": [{ "type": "object", "properties": {}, "title": "Address" }]
                                        },
                                        "billingAddress": {
                                            "description": "Billing address",
                                            "allOf": [{ "type": "object", "properties": {}, "title": "Address" }]
                                        },
                                        "shippingMethods": {
                                            "description": "Selected shipping methods",
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id": {
                                                        "type": "string",
                                                        "description": "Shipping method identifier"
                                                    },
                                                    "name": {
                                                        "type": "string",
                                                        "description": "Shipping method display name"
                                                    },
                                                    "description": {
                                                        "type": "string",
                                                        "description": "Shipping method description"
                                                    },
                                                    "total": {
                                                        "type": "object",
                                                        "description": "Total shipping cost including tax"
                                                    },
                                                    "subtotal": {
                                                        "type": "object",
                                                        "description": "Shipping cost before tax"
                                                    }
                                                },
                                                "required": ["id", "name"],
                                                "title": "ShippingMethod"
                                            }
                                        },
                                        "customerComment": {
                                            "type": "string",
                                            "description": "Customer notes or comments"
                                        },
                                        "documents": {
                                            "description": "Associated documents (invoices, receipts)",
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "id": { "type": "string", "description": "Document identifier" },
                                                    "createdAt": {
                                                        "type": "string",
                                                        "description": "Document creation timestamp in ISO 8601 format"
                                                    },
                                                    "updatedAt": {
                                                        "type": "string",
                                                        "description": "Last update timestamp in ISO 8601 format"
                                                    },
                                                    "type": {
                                                        "type": "string",
                                                        "description": "Document type (e.g., invoice, receipt)"
                                                    },
                                                    "orderId": {
                                                        "type": "string",
                                                        "description": "Associated order identifier"
                                                    },
                                                    "dueDate": {
                                                        "type": "string",
                                                        "description": "Payment due date in ISO 8601 format"
                                                    },
                                                    "status": {
                                                        "type": "string",
                                                        "description": "Document payment status",
                                                        "enum": [
                                                            "PENDING",
                                                            "PAID",
                                                            "FAILED",
                                                            "REFUNDED",
                                                            "NOT_PAID",
                                                            "CAPTURED",
                                                            "PARTIALLY_REFUNDED",
                                                            "REQUIRES_ACTION",
                                                            "UNKNOWN"
                                                        ]
                                                    },
                                                    "toBePaid": {
                                                        "type": "object",
                                                        "description": "Amount remaining to be paid"
                                                    },
                                                    "total": {
                                                        "type": "object",
                                                        "description": "Total document amount"
                                                    }
                                                },
                                                "required": [
                                                    "id",
                                                    "createdAt",
                                                    "updatedAt",
                                                    "type",
                                                    "orderId",
                                                    "dueDate",
                                                    "status",
                                                    "toBePaid",
                                                    "total"
                                                ],
                                                "title": "Document"
                                            }
                                        },
                                        "email": {
                                            "type": "string",
                                            "description": "Customer email for guest order confirmation"
                                        }
                                    },
                                    "required": [
                                        "id",
                                        "createdAt",
                                        "updatedAt",
                                        "total",
                                        "currency",
                                        "paymentStatus",
                                        "status",
                                        "items",
                                        "shippingMethods"
                                    ],
                                    "title": "Order"
                                }
                            },
                            "total": { "type": "number", "description": "Total number of orders matching the query" }
                        },
                        "required": ["data", "total"],
                        "title": "PaginatedOrders"
                    }
                }
            }
        }
    }
}
