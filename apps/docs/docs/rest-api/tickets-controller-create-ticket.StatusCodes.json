{
    "responses": {
        "201": {
            "description": "Ticket created.",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "id": { "type": "string", "description": "Unique ticket identifier" },
                            "createdAt": {
                                "type": "string",
                                "description": "Ticket creation timestamp in ISO 8601 format"
                            },
                            "updatedAt": {
                                "type": "string",
                                "description": "Last update timestamp in ISO 8601 format"
                            },
                            "topic": { "type": "string", "description": "Ticket subject/topic" },
                            "type": { "type": "string", "description": "Ticket type/category" },
                            "status": {
                                "type": "string",
                                "description": "Current ticket status",
                                "enum": ["OPEN", "CLOSED", "IN_PROGRESS"]
                            },
                            "properties": {
                                "description": "Custom ticket properties",
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "id": { "type": "string", "description": "Property identifier" },
                                        "value": { "type": "string", "description": "Property value" }
                                    },
                                    "required": ["id", "value"],
                                    "title": "TicketProperty"
                                }
                            },
                            "attachments": {
                                "description": "Attached files",
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "name": { "type": "string", "description": "Attachment file name" },
                                        "url": { "type": "string", "description": "URL to download the attachment" },
                                        "size": { "type": "number", "description": "File size in bytes" },
                                        "author": {
                                            "description": "User who uploaded the attachment",
                                            "allOf": [
                                                {
                                                    "type": "object",
                                                    "properties": {
                                                        "name": {
                                                            "type": "string",
                                                            "description": "Author display name"
                                                        },
                                                        "position": {
                                                            "type": "string",
                                                            "description": "Author job position"
                                                        },
                                                        "email": {
                                                            "type": "string",
                                                            "description": "Author email address"
                                                        },
                                                        "avatar": {
                                                            "description": "Author avatar image",
                                                            "allOf": [
                                                                { "type": "object", "properties": {}, "title": "Media" }
                                                            ]
                                                        }
                                                    },
                                                    "required": ["name"],
                                                    "title": "Author"
                                                }
                                            ]
                                        },
                                        "date": { "type": "string", "description": "Upload date in ISO 8601 format" },
                                        "ariaLabel": {
                                            "type": "string",
                                            "description": "Accessible label for screen readers"
                                        }
                                    },
                                    "required": ["name", "url", "size", "author", "date", "ariaLabel"],
                                    "title": "TicketAttachment"
                                }
                            },
                            "comments": {
                                "description": "Ticket conversation thread",
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "author": {
                                            "description": "Comment author",
                                            "allOf": [
                                                {
                                                    "type": "object",
                                                    "properties": {
                                                        "name": {
                                                            "type": "string",
                                                            "description": "Author display name"
                                                        },
                                                        "position": {
                                                            "type": "string",
                                                            "description": "Author job position"
                                                        },
                                                        "email": {
                                                            "type": "string",
                                                            "description": "Author email address"
                                                        },
                                                        "avatar": {
                                                            "description": "Author avatar image",
                                                            "allOf": [
                                                                { "type": "object", "properties": {}, "title": "Media" }
                                                            ]
                                                        }
                                                    },
                                                    "required": ["name"],
                                                    "title": "Author"
                                                }
                                            ]
                                        },
                                        "date": { "type": "string", "description": "Comment date in ISO 8601 format" },
                                        "content": { "type": "string", "description": "Comment text content" }
                                    },
                                    "required": ["author", "date", "content"],
                                    "title": "TicketComment"
                                }
                            }
                        },
                        "required": ["id", "createdAt", "updatedAt", "topic", "status", "properties"],
                        "title": "Ticket"
                    }
                }
            }
        }
    }
}
