{
    "responses": {
        "200": {
            "description": "Returns invoice details.",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "id": { "type": "string", "description": "Unique invoice identifier" },
                            "externalId": { "type": "string", "description": "External system invoice identifier" },
                            "billingAccountId": {
                                "type": "string",
                                "description": "Associated billing account identifier"
                            },
                            "billingPeriod": { "type": "string", "description": "Billing period (e.g., \"2024-01\")" },
                            "paymentMethodId": { "type": "string", "description": "Payment method identifier" },
                            "type": {
                                "type": "string",
                                "description": "Invoice type",
                                "enum": ["STANDARD", "PROFORMA", "CREDIT_NOTE", "DEBIT_NOTE"]
                            },
                            "paymentStatus": {
                                "type": "string",
                                "description": "Payment status",
                                "enum": ["PAYMENT_COMPLETE", "PAYMENT_DECLINED", "PAYMENT_DUE", "PAYMENT_PAST_DUE"]
                            },
                            "issuedDate": { "type": "string", "description": "Invoice issue date in ISO 8601 format" },
                            "currency": { "type": "string", "description": "Invoice currency code" },
                            "paymentDueDate": {
                                "type": "string",
                                "description": "Payment due date in ISO 8601 format"
                            },
                            "totalAmountDue": { "type": "object", "description": "Total amount due including tax" },
                            "totalNetAmountDue": { "type": "object", "description": "Net amount due before tax" },
                            "totalAmountPaid": { "type": "object", "description": "Amount already paid" },
                            "totalToBePaid": { "type": "object", "description": "Remaining amount to be paid" }
                        },
                        "required": [
                            "id",
                            "externalId",
                            "billingAccountId",
                            "billingPeriod",
                            "paymentMethodId",
                            "type",
                            "paymentStatus",
                            "issuedDate",
                            "currency",
                            "paymentDueDate",
                            "totalAmountDue",
                            "totalNetAmountDue",
                            "totalAmountPaid",
                            "totalToBePaid"
                        ],
                        "title": "Invoice"
                    }
                }
            }
        }
    }
}
