{
    "title": "Body",
    "body": {
        "required": true,
        "description": "Search query and filters.",
        "content": {
            "application/json": {
                "schema": {
                    "type": "object",
                    "properties": {
                        "query": { "type": "string", "description": "Search query string" },
                        "exact": {
                            "type": "object",
                            "description": "Exact match filters",
                            "additionalProperties": true
                        },
                        "range": {
                            "type": "object",
                            "description": "Range filters (min/max)",
                            "additionalProperties": true
                        },
                        "exists": {
                            "description": "Fields that must exist",
                            "type": "array",
                            "items": { "type": "string" }
                        },
                        "notExists": {
                            "description": "Fields that must not exist",
                            "type": "array",
                            "items": { "type": "string" }
                        },
                        "pagination": {
                            "description": "Pagination settings",
                            "allOf": [
                                {
                                    "type": "object",
                                    "properties": {
                                        "offset": { "type": "number", "description": "Number of results to skip" },
                                        "limit": {
                                            "type": "number",
                                            "description": "Maximum number of results to return"
                                        }
                                    },
                                    "title": "SearchPagination"
                                }
                            ]
                        },
                        "filter": {
                            "type": "object",
                            "description": "Additional filters",
                            "additionalProperties": true
                        },
                        "metadata": {
                            "type": "object",
                            "description": "Additional metadata",
                            "additionalProperties": true
                        },
                        "sort": {
                            "description": "Sort configuration",
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "field": { "type": "string", "description": "Field name to sort by" },
                                    "order": {
                                        "type": "string",
                                        "description": "Sort direction",
                                        "enum": ["asc", "desc"]
                                    }
                                },
                                "required": ["field", "order"],
                                "title": "SearchSortOption"
                            }
                        },
                        "locale": { "type": "string", "description": "Locale for localized results" }
                    },
                    "title": "SearchPayload"
                }
            }
        }
    }
}
