{
    "responses": {
        "200": {
            "description": "Returns article categories list.",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "data": {
                                "description": "Array of categories",
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "id": { "type": "string", "description": "Unique category identifier" },
                                        "slug": { "type": "string", "description": "URL-friendly category slug" },
                                        "createdAt": {
                                            "type": "string",
                                            "description": "Category creation timestamp in ISO 8601 format"
                                        },
                                        "updatedAt": {
                                            "type": "string",
                                            "description": "Last update timestamp in ISO 8601 format"
                                        },
                                        "title": { "type": "string", "description": "Category display title" },
                                        "description": { "type": "string", "description": "Category description" },
                                        "icon": { "type": "string", "description": "Category icon identifier" },
                                        "parent": {
                                            "description": "Parent category hierarchy",
                                            "allOf": [
                                                {
                                                    "type": "object",
                                                    "properties": {
                                                        "slug": {
                                                            "type": "string",
                                                            "description": "Parent category slug"
                                                        },
                                                        "title": {
                                                            "type": "string",
                                                            "description": "Parent category title"
                                                        },
                                                        "parent": {
                                                            "description": "Grandparent category",
                                                            "allOf": ["circular(CategoryParent)"]
                                                        }
                                                    },
                                                    "required": ["slug", "title"],
                                                    "title": "CategoryParent"
                                                }
                                            ]
                                        }
                                    },
                                    "required": ["id", "slug", "createdAt", "updatedAt", "title", "description"],
                                    "title": "Category"
                                }
                            },
                            "total": { "type": "number", "description": "Total number of categories" }
                        },
                        "required": ["data", "total"],
                        "title": "PaginatedCategories"
                    }
                }
            }
        }
    }
}
