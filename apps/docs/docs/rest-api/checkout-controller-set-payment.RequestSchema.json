{
    "title": "Body",
    "body": {
        "required": true,
        "description": "Payment provider selection payload.",
        "content": {
            "application/json": {
                "schema": {
                    "type": "object",
                    "properties": {
                        "providerId": { "type": "string", "description": "Payment provider identifier." },
                        "returnUrl": {
                            "type": "string",
                            "description": "URL used for redirect after successful payment flow."
                        },
                        "cancelUrl": {
                            "type": "string",
                            "description": "Optional URL used for redirect when payment flow is canceled."
                        },
                        "metadata": {
                            "type": "object",
                            "description": "Provider-specific metadata payload.",
                            "additionalProperties": true
                        }
                    },
                    "required": ["providerId", "returnUrl"],
                    "title": "SetPaymentBody"
                }
            }
        }
    }
}
