{
    "title": "Body",
    "body": {
        "required": true,
        "content": {
            "application/json": {
                "schema": {
                    "type": "object",
                    "properties": {
                        "cartId": {
                            "type": "string",
                            "description": "Existing cart identifier. If omitted, implementation may create/find active cart."
                        },
                        "sku": { "type": "string", "description": "Product SKU identifier." },
                        "quantity": { "type": "number", "description": "Item quantity." },
                        "variantId": {
                            "type": "string",
                            "description": "Optional integration-specific variant identifier (e.g. Medusa variant UUID)."
                        },
                        "currency": {
                            "type": "string",
                            "description": "Currency code (typically required when a new cart is created)."
                        },
                        "regionId": {
                            "type": "string",
                            "description": "Region identifier (typically required when a new cart is created)."
                        },
                        "metadata": {
                            "type": "object",
                            "description": "Integration-specific item metadata payload.",
                            "additionalProperties": true
                        },
                        "locale": {
                            "type": "string",
                            "description": "Optional locale provided in the request body (kept as string)."
                        }
                    },
                    "required": ["sku", "quantity"],
                    "title": "AddCartItemBody"
                }
            }
        }
    }
}
