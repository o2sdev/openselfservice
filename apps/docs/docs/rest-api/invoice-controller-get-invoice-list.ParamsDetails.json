{
    "parameters": [
        {
            "name": "paymentStatus",
            "required": false,
            "in": "query",
            "description": "Filter invoices by payment status.",
            "schema": {
                "type": "string",
                "enum": ["PAYMENT_COMPLETE", "PAYMENT_DECLINED", "PAYMENT_DUE", "PAYMENT_PAST_DUE"]
            }
        },
        {
            "name": "type",
            "required": false,
            "in": "query",
            "description": "Filter invoices by invoice type.",
            "schema": { "type": "string", "enum": ["STANDARD", "PROFORMA", "CREDIT_NOTE", "DEBIT_NOTE"] }
        },
        {
            "name": "dateFrom",
            "required": false,
            "in": "query",
            "description": "Include invoices issued from this date (ISO string).",
            "schema": { "type": "string" }
        },
        {
            "name": "dateTo",
            "required": false,
            "in": "query",
            "description": "Include invoices issued until this date (ISO string).",
            "schema": { "type": "string" }
        },
        {
            "name": "sort",
            "required": false,
            "in": "query",
            "description": "Sort expression, for example `issuedDate_DESC`.",
            "schema": { "type": "string" }
        },
        {
            "name": "search",
            "required": false,
            "in": "query",
            "description": "Free-text search phrase for invoice content/number.",
            "schema": { "type": "string" }
        },
        {
            "name": "locale",
            "required": false,
            "in": "query",
            "description": "Optional locale code used to localize response values.",
            "schema": { "type": "string" }
        },
        {
            "name": "query",
            "required": false,
            "in": "query",
            "description": "Invoice list filters and pagination query.",
            "schema": { "type": "string" }
        }
    ]
}
