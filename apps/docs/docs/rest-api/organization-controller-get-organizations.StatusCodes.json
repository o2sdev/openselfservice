{
    "responses": {
        "200": {
            "description": "Returns organizations list.",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "data": {
                                "description": "Array of organizations",
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "isActive": {
                                            "type": "boolean",
                                            "description": "Whether the organization is currently active"
                                        },
                                        "taxId": { "type": "string", "description": "Tax identification number" },
                                        "children": {
                                            "description": "Child organizations in hierarchy",
                                            "type": "array",
                                            "items": "circular(Organization)"
                                        },
                                        "customers": {
                                            "description": "Customers associated with this organization",
                                            "type": "array",
                                            "items": { "type": "object", "properties": {}, "title": "Customer" }
                                        }
                                    },
                                    "required": ["isActive", "taxId", "children", "customers"],
                                    "title": "Organization"
                                }
                            },
                            "total": {
                                "type": "number",
                                "description": "Total number of organizations matching the query"
                            }
                        },
                        "required": ["data", "total"],
                        "title": "PaginatedOrganizations"
                    }
                }
            }
        }
    }
}
