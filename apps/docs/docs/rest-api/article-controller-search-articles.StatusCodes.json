{
    "responses": {
        "200": {
            "description": "Returns article search results.",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "data": {
                                "description": "Array of articles",
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "id": { "type": "string", "description": "Unique article identifier" },
                                        "slug": { "type": "string", "description": "URL-friendly article slug" },
                                        "createdAt": {
                                            "type": "string",
                                            "description": "Article creation timestamp in ISO 8601 format"
                                        },
                                        "updatedAt": {
                                            "type": "string",
                                            "description": "Last update timestamp in ISO 8601 format"
                                        },
                                        "title": { "type": "string", "description": "Article title" },
                                        "lead": { "type": "string", "description": "Article lead/summary paragraph" },
                                        "tags": {
                                            "description": "Article tags",
                                            "type": "array",
                                            "items": { "type": "string" }
                                        },
                                        "image": {
                                            "description": "Main article image",
                                            "allOf": [{ "type": "object", "properties": {}, "title": "Media" }]
                                        },
                                        "thumbnail": {
                                            "description": "Article thumbnail image",
                                            "allOf": [{ "type": "object", "properties": {}, "title": "Media" }]
                                        },
                                        "category": {
                                            "description": "Article category reference",
                                            "allOf": [
                                                {
                                                    "type": "object",
                                                    "properties": {
                                                        "id": {
                                                            "type": "string",
                                                            "description": "Category identifier"
                                                        },
                                                        "title": { "type": "string", "description": "Category title" }
                                                    },
                                                    "required": ["id", "title"],
                                                    "title": "ArticleCategoryRef"
                                                }
                                            ]
                                        },
                                        "author": {
                                            "description": "Article author",
                                            "allOf": [
                                                {
                                                    "type": "object",
                                                    "properties": {
                                                        "name": {
                                                            "type": "string",
                                                            "description": "Author display name"
                                                        },
                                                        "position": {
                                                            "type": "string",
                                                            "description": "Author job position"
                                                        },
                                                        "email": {
                                                            "type": "string",
                                                            "description": "Author email address"
                                                        },
                                                        "avatar": {
                                                            "description": "Author avatar image",
                                                            "allOf": [
                                                                { "type": "object", "properties": {}, "title": "Media" }
                                                            ]
                                                        }
                                                    },
                                                    "required": ["name"],
                                                    "title": "Author"
                                                }
                                            ]
                                        },
                                        "roles": {
                                            "description": "Role-based access control roles",
                                            "type": "array",
                                            "items": { "type": "string" }
                                        },
                                        "theme": { "type": "string", "description": "Article theme/style variant" }
                                    },
                                    "required": ["id", "slug", "createdAt", "updatedAt", "title", "lead", "tags"],
                                    "title": "ArticleListItem"
                                }
                            },
                            "total": { "type": "number", "description": "Total number of articles" }
                        },
                        "required": ["data", "total"],
                        "title": "PaginatedArticles"
                    }
                }
            }
        }
    }
}
